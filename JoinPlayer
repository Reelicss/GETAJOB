const API_URL = "https://your-api-endpoint.com/active-users";

async function fetchActiveExecutors() {
    try {
        const response = await fetch(API_URL);
        if (!response.ok) {
            throw new Error(response.status);
        }
        const data = await response.json();
        return data;
    } catch (error) {
        return [];
    }
}

function joinUser(placeId, jobId) {
    window.location.href = `roblox://experiences/start?placeId=${placeId}&gameInstanceId=${jobId}`;
}
